<!DOCTYPE html>


<html dir="ltr" lang="en-gb">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width">
        <title>Error 404</title><link rel="shortcut icon" type="image/png" href="/img/d5001a95606c2e30.webp?r=1774489796">
        <link rel='stylesheet' id='theme-css'  href='/css/style.css?r=1774489796' type='text/css' media='all' /></head>
    <body>
        <div class="error error_404">
            <div class="error__container">
                <div class="error__image"></div>
                <div class="error__message">
                    <h2 class="error__header">
                        WE&#39;RE SORRY! NO SUCH PAGE FOUND!
                    </h2>

                    <p class="error__text">
                        The page you&#39;re requesting does not exist or has been deleted. Please verify the address entered.
                    </p>

                    <div class="error__buttons">
                        <a href="/booking/"
                           class="error__button error__button_booking">BOOK A ROOM</a>
                        <a href="/" class="error__button error__button_goto_main">HOME</a>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>